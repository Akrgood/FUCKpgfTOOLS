    def on_zoom_change(self, val):
        self.cell_size = int(val)
        if self.active_char_index is not None:
            self.draw_char(self.active_char_index)

    def on_search(self, event=None):
        query = self.search_entry.get().lower()
        self.populate_char_list(query)

    def load_file(self):
        path = filedialog.askopenfilename(filetypes=[("PGF Fonts", "*.pgf"), ("All Files", "*.*")])
        if path:
            with open(path, "rb") as f:
                self.parse_pgf(f.read())
                
    def save_file(self):
        if not self.pgf_data: return
        self.serialize_active_char()
        path = filedialog.asksaveasfilename(defaultextension=".pgf")
        if path:
            data = self.serialize_pgf()
            with open(path, "wb") as f:
                f.write(data)

    def paint(self, event):
        if self.active_char_index is None: return
        char = self.pgf_data['chars'][self.active_char_index]
        if not char or 'w' not in char: return
        
        x = event.x // self.cell_size
        y = event.y // self.cell_size
        
        if 0 <= x < char['w'] and 0 <= y < char['h']:
            if self.current_tool.get() == "Pencil":
                char['data'][y * char['w'] + x] = self.active_brush
                self.draw_char(self.active_char_index)
            elif self.current_tool.get() == "Picker":
                val = char['data'][y * char['w'] + x]
                self.set_brush(val)
                self.current_tool.set("Pencil")

    def parse_pgf(self, data):
        view = ReadStream(data)
        pgf = {}
        
        pgf['header'] = {
            'offset': view.read_u16(), 'size': view.read_u16(),
            'magic': view.read_str(4), 'revision': view.read_s32(),
            'version': view.read_s32(), 'charMapLength': view.read_u32(),
            'charPointerLength': view.read_u32(), 'charMapBpe': view.read_u32(),
            'charPointerBpe': view.read_u32(), 'unk1': view.read_u8(),
            'unk2': view.read_u8(), 'bpp': view.read_u8(), 'unk3': view.read_u8(),
            'hSize': view.read_s32(), 'vSize': view.read_s32(),
            'hResolution': view.read_s32(), 'vResolution': view.read_s32(),
            'unk4': view.read_u8(), 'fontName': view.read_str(64),
            'fontType': view.read_str(64), 'unk5': view.read_u8(),
            'firstGlyph': view.read_u16(), 'lastGlyph': view.read_u16(),
            'unk6': view.read_str(26), 'maxAscender': view.read_s32(),
            'maxDescender': view.read_s32(), 'maxLeftXAdjust': view.read_s32(),
            'maxBaseYAdjust': view.read_s32(), 'minCenterXAdjust': view.read_s32(),
            'maxTopYAdjust': view.read_s32(), 'maxAdvanceX': view.read_s32(),
            'maxAdvanceY': view.read_s32(), 'maxSizeX': view.read_s32(),
            'maxSizeY': view.read_s32(), 'maxGlyphWidth': view.read_u16(),
            'maxGlyphHeight': view.read_u16(), 'unk7': view.read_u8(),
            'unk8': view.read_u8(), 'dimTableLength': view.read_u8(),
            'xAdjustTableLength': view.read_u8(), 'yAdjustTableLength': view.read_u8(),
            'advanceTableLength': view.read_u8(), 'unk9': view.read_str(102),
            'shadowMapLength': view.read_s32(), 'shadowMapBpe': view.read_s32(),
            'unk10': view.read_u32(), 'shadowScale0': view.read_s32(),
            'shadowScale1': view.read_s32(), 'unk11': view.read_str(8)
        }
        
        pgf['dimTable'] = [{'w': view.read_u32(), 'h': view.read_u32()} for _ in range(pgf['header']['dimTableLength'])]
        pgf['xAdjustTable'] = [{'horiz': view.read_s32(), 'vert': view.read_s32()} for _ in range(pgf['header']['xAdjustTableLength'])]
        pgf['yAdjustTable'] = [{'horiz': view.read_s32(), 'vert': view.read_s32()} for _ in range(pgf['header']['yAdjustTableLength'])]
        pgf['advanceTable'] = [{'horiz': view.read_s32(), 'vert': view.read_s32()} for _ in range(pgf['header']['advanceTableLength'])]
        
        pgf['shadowMap'] = [view.read_bits(pgf['header']['shadowMapBpe']) for _ in range(pgf['header']['shadowMapLength'])]
        view.align(4)
        
        pgf['charMap'] = [view.read_bits(pgf['header']['charMapBpe']) for _ in range(pgf['header']['charMapLength'])]
        view.align(4)
        
        pgf['charPointers'] = [view.read_bits(pgf['header']['charPointerBpe']) for _ in range(pgf['header']['charPointerLength'])]
        view.align(4)
        
        fontdata = view.tell()
        pgf['glyphs'] = []
        for i in range(pgf['header']['charPointerLength']):
            view.seek(fontdata + pgf['charPointers'][i] * 4)
            pgf['glyphs'].append(self.read_char_glyph(view, pgf))
            
        pgf['chars'] = [None] * pgf['header']['firstGlyph']
        for i in range(pgf['header']['charMapLength']):
            if i < len(pgf['charMap']):
                mapped_idx = pgf['charMap'][i]
                glyph = pgf['glyphs'][mapped_idx] if mapped_idx < len(pgf['glyphs']) else {}
                pgf['chars'].append(glyph)
                
        self.pgf_data = pgf
        self.search_entry.delete(0, tk.END)
        self.populate_char_list()

    def read_char_glyph(self, view, pgf):
        info = {
            'size': view.read_bits(14), 'w': view.read_bits(7), 'h': view.read_bits(7),
            'left': view.read_bits(7), 'top': view.read_bits(7), 'flags': view.read_bits(6),
            'shadowFlags': (view.read_bits(2) << 5) | (view.read_bits(2) << 3) | view.read_bits(3),
            'shadowID': view.read_bits(9)
        }
        if info['left'] >= 64: info['left'] -= 128
        if info['top'] >= 64: info['top'] -= 128
        
        if info['flags'] & 4:
            idx = view.read_u8()
            if idx < len(pgf['dimTable']):
                info['dimensionWidth'], info['dimensionHeight'] = pgf['dimTable'][idx]['w'], pgf['dimTable'][idx]['h']
        else:
            info['dimensionWidth'], info['dimensionHeight'] = view.read_s32(), view.read_s32()
            
        if info['flags'] & 8:
            idx = view.read_u8()
            if idx < len(pgf['xAdjustTable']):
                info['xAdjustH'], info['xAdjustV'] = pgf['xAdjustTable'][idx]['horiz'], pgf['xAdjustTable'][idx]['vert']
        else:
            info['xAdjustH'], info['xAdjustV'] = view.read_s32(), view.read_s32()
            
        if info['flags'] & 16:
            idx = view.read_u8()
            if idx < len(pgf['yAdjustTable']):
                info['yAdjustH'], info['yAdjustV'] = pgf['yAdjustTable'][idx]['horiz'], pgf['yAdjustTable'][idx]['vert']
        else:
            info['yAdjustH'], info['yAdjustV'] = view.read_s32(), view.read_s32()
            
        if info['flags'] & 32:
            idx = view.read_u8()
            if idx < len(pgf['advanceTable']):
                info['advanceH'], info['advanceV'] = pgf['advanceTable'][idx]['horiz'], pgf['advanceTable'][idx]['vert']
        else:
            info['advanceH'], info['advanceV'] = view.read_s32(), view.read_s32()
            
        use_h = (info['flags'] & 3) == 1
        use_v = (info['flags'] & 3) == 2
        
        if use_h or use_v:
            info['data'] = [0] * (info['w'] * info['h'])
            i = 0
            while i < len(info['data']):
                nibble = view.read_bits(4)
                if nibble < 8:
                    color = view.read_bits(4)
                    count = nibble + 1
                    for j in range(count):
                        if i + j < len(info['data']): info['data'][i + j] = color
                    i += count
                else:
                    count = 16 - nibble
                    for j in range(count):
                        if i + j < len(info['data']): info['data'][i + j] = view.read_bits(4)
                    i += count
                    
            if use_v:
                newdata = [0] * len(info['data'])
                for y in range(info['h']):
                    for x in range(info['w']):
                        idx = y * info['w'] + x
                        newx, newy = idx // info['h'], idx % info['h']
                        newdata[newy * info['w'] + newx] = info['data'][idx]
                info['data'] = newdata
        return info

    def populate_char_list(self, query=""):
        self.char_listbox.delete(0, tk.END)
        self.listbox_mapping.clear()
        
        for i, char in enumerate(self.pgf_data['chars']):
            if char is None or 'w' not in char: continue
            
            char_str = chr(i) if i > 32 else ""
            label = f"{i} ('{char_str}')" if char_str else str(i)
            
            if query and query not in label.lower():
                continue
                
            self.char_listbox.insert(tk.END, label)
            self.listbox_mapping.append(i)
            
        if self.listbox_mapping and self.active_char_index not in self.listbox_mapping:
            if 65 in self.listbox_mapping:
                target = 65
            else:
                target = self.listbox_mapping[0]
            
            list_idx = self.listbox_mapping.index(target)
            self.char_listbox.selection_set(list_idx)
            self.select_char(target)

    def on_listbox_select(self, event):
        selection = self.char_listbox.curselection()
        if not selection: return
        list_idx = selection[0]
        actual_char_index = self.listbox_mapping[list_idx]
        self.select_char(actual_char_index)

    def select_char(self, idx):
        if self.active_char_index is not None and self.active_char_index != idx:
            self.serialize_active_char()
        self.active_char_index = idx
        self.draw_char(idx)
        self.update_metrics(idx)

    def draw_char(self, idx):
        self.canvas.delete("all")
        char = self.pgf_data['chars'][idx]
        if 'w' not in char or 'data' not in char: return
        
        self.canvas.config(width=char['w'] * self.cell_size, height=char['h'] * self.cell_size)
        for y in range(char['h']):
            for x in range(char['w']):
                val = char['data'][y * char['w'] + x]
                shade = int((val / 15.0) * 255)
                color = f"#{shade:02x}{shade:02x}{shade:02x}"
                self.canvas.create_rectangle(x * self.cell_size, y * self.cell_size,
                                             (x + 1) * self.cell_size, (y + 1) * self.cell_size,
                                             fill=color, outline="#333333")

    def update_metrics(self, idx):
        char = self.pgf_data['chars'][idx]
        for key, entry in self.metrics_entries.items():
            entry.delete(0, tk.END)
            val = char.get(key, 0)
            if key in ["dimensionWidth", "dimensionHeight", "xAdjustH", "xAdjustV", 
                       "yAdjustH", "yAdjustV", "advanceH", "advanceV"]:
                val = val / 64.0
            entry.insert(0, str(val))

    def serialize_active_char(self):
        if self.active_char_index is None: return
        char = self.pgf_data['chars'][self.active_char_index]
        for key, entry in self.metrics_entries.items():
            try:
                val = float(entry.get())
                if key in ["dimensionWidth", "dimensionHeight", "xAdjustH", "xAdjustV", 
                           "yAdjustH", "yAdjustV", "advanceH", "advanceV"]:
                    val = int(val * 64)
                else:
                    val = int(val)
                char[key] = val
            except ValueError:
                pass

    def serialize_pgf(self):
        header = self.pgf_data['header']
        header_stream = WriteStream()
        
        glyphs = []
        for glyph in self.pgf_data['glyphs']:
            glyphs.append(self.make_char_glyph(glyph))
            
        header['revision'] = 2
        header['size'] = 392 if header['revision'] == 3 else 372
        header['version'] = 6
        header['dimTableLength'] = 0
        header['xAdjustTableLength'] = 0
        header['yAdjustTableLength'] = 0
        header['advanceTableLength'] = 0
        header['shadowMapLength'] = 0
        header['charPointerBpe'] = 24
        
        header_stream.write_u16(header['offset'])
        header_stream.write_u16(header['size'])
        header_stream.write_str(4, header['magic'])
        header_stream.write_s32(header['revision'])
        header_stream.write_s32(header['version'])
        header_stream.write_u32(header['charMapLength'])
        header_stream.write_u32(header['charPointerLength'])
        header_stream.write_u32(header['charMapBpe'])
        header_stream.write_u32(header['charPointerBpe'])
        header_stream.write_u8(header['unk1'])
        header_stream.write_u8(header['unk2'])
        header_stream.write_u8(header['bpp'])
        header_stream.write_u8(header['unk3'])
        header_stream.write_s32(header['hSize'])
        header_stream.write_s32(header['vSize'])
        header_stream.write_s32(header['hResolution'])
        header_stream.write_s32(header['vResolution'])
        header_stream.write_u8(header['unk4'])
        header_stream.write_str(64, header['fontName'])
        header_stream.write_str(64, header['fontType'])
        header_stream.write_u8(header['unk5'])
        header_stream.write_u16(header['firstGlyph'])
        header_stream.write_u16(header['lastGlyph'])
        header_stream.write_str(26, header['unk6'])
        header_stream.write_s32(header['maxAscender'])
        header_stream.write_s32(header['maxDescender'])
        header_stream.write_s32(header['maxLeftXAdjust'])
        header_stream.write_s32(header['maxBaseYAdjust'])
        header_stream.write_s32(header['minCenterXAdjust'])
        header_stream.write_s32(header['maxTopYAdjust'])
        header_stream.write_s32(header['maxAdvanceX'])
        header_stream.write_s32(header['maxAdvanceY'])
        header_stream.write_s32(header['maxSizeX'])
        header_stream.write_s32(header['maxSizeY'])
        header_stream.write_u16(header['maxGlyphWidth'])
        header_stream.write_u16(header['maxGlyphHeight'])
        header_stream.write_u8(header['unk7'])
        header_stream.write_u8(header['unk8'])
        header_stream.write_u8(header['dimTableLength'])
        header_stream.write_u8(header['xAdjustTableLength'])
        header_stream.write_u8(header['yAdjustTableLength'])
        header_stream.write_u8(header['advanceTableLength'])
        header_stream.write_str(102, header['unk9'])
        header_stream.write_s32(header['shadowMapLength'])
        header_stream.write_s32(header['shadowMapBpe'])
        header_stream.write_u32(header['unk10'])
        header_stream.write_s32(header['shadowScale0'])
        header_stream.write_s32(header['shadowScale1'])
        header_stream.write_str(8, header['unk11'])
        
        header_stream.align(4)
        for val in self.pgf_data['charMap']:
            header_stream.write_bits(header['charMapBpe'], val)
        header_stream.align(4)
        
        next_ptr = 0
        for g in glyphs:
            header_stream.write_bits(header['charPointerBpe'], next_ptr)
            next_ptr += len(g) // 4
        header_stream.align(4)
        
        out = bytearray(header_stream.get_data())
        for g in glyphs:
            out.extend(g)
        return bytes(out)

    def make_char_glyph(self, info):
        info['flags'] = 1 if (info['flags'] & 3) else 0
        glyph_stream = WriteStream()
        
        if info['flags'] & 3:
            data_len = len(info['data'])
            i = 0
            while i < data_len:
                c = info['data'][i]
                max_span = min(7, data_len - i - 1)
                span = 0
                for j in range(1, max_span + 1):
                    if c != info['data'][i + j]: break
                    span = j
                    
                if span != 0 or max_span < 2:
                    glyph_stream.write_bits(4, span)
                    glyph_stream.write_bits(4, c)
                    i += span + 1
                else:
                    span = 2
                    for j in range(3, max_span + 1):
                        if info['data'][i + j - 1] == info['data'][i + j]: break
                        span = j - 1
                    glyph_stream.write_bits(4, 15 - span)
                    glyph_stream.write_bits(4, c)
                    for j in range(1, span + 1):
                        glyph_stream.write_bits(4, info['data'][i + j])
                    i += span + 1
            glyph_stream.align(4)
            
        header_stream = WriteStream()
        glyph_data = glyph_stream.get_data()
        size = 8 + len(glyph_data)
        if info['flags'] & 4: size += 1 
        else: size += 8
        if info['flags'] & 8: size += 1 
        else: size += 8
        if info['flags'] & 16: size += 1 
        else: size += 8
        if info['flags'] & 32: size += 1 
        else: size += 8
        
        info['size'] = size
        info['shadowFlags'] = 0
        info['shadowID'] = 0
        
        header_stream.write_bits(14, info['size'])
        header_stream.write_bits(7, info.get('w', 0))
        header_stream.write_bits(7, info.get('h', 0))
        left = info.get('left', 0)
        header_stream.write_bits(7, left + 128 if left < 0 else left)
        top = info.get('top', 0)
        header_stream.write_bits(7, top + 128 if top < 0 else top)
        header_stream.write_bits(6, info['flags'])
        header_stream.write_bits(7, (info['shadowFlags'] >> 5) | ((info['shadowFlags'] & 0x18) >> 1) | ((info['shadowFlags'] & 0x07) << 4))
        header_stream.write_bits(9, info['shadowID'])
        header_stream.flush_bits()
        
        header_stream.write_s32(info.get('dimensionWidth', 0))
        header_stream.write_s32(info.get('dimensionHeight', 0))
        header_stream.write_s32(info.get('xAdjustH', 0))
        header_stream.write_s32(info.get('xAdjustV', 0))
        header_stream.write_s32(info.get('yAdjustH', 0))
        header_stream.write_s32(info.get('yAdjustV', 0))
        header_stream.write_s32(info.get('advanceH', 0))
        header_stream.write_s32(info.get('advanceV', 0))
        
        return header_stream.get_data() + glyph_data

