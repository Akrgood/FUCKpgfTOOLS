class ReadStream:
    def __init__(self, data: bytes):
        self.data = data
        self.pos = 0
        self.bitpos = 0

    def read_u8(self):
        v = self.data[self.pos]
        self.pos += 1
        return v

    def read_u16(self):
        v = struct.unpack_from('<H', self.data, self.pos)[0]
        self.pos += 2
        return v

    def read_s32(self):
        v = struct.unpack_from('<i', self.data, self.pos)[0]
        self.pos += 4
        return v

    def read_u32(self):
        v = struct.unpack_from('<I', self.data, self.pos)[0]
        self.pos += 4
        return v

    def read_str(self, length):
        s = self.data[self.pos:self.pos+length].split(b'\x00')[0].decode('ascii', 'ignore')
        self.pos += length
        return s

    def read_bits(self, length):
        res = 0
        if self.bitpos + length < 32:
            if self.pos + 4 <= len(self.data):
                dword = struct.unpack_from('<I', self.data, self.pos)[0]
                mask = (1 << length) - 1
                res = (dword >> self.bitpos) & mask
                self.bitpos += length
            else:
                remaining = length
                while remaining > 0:
                    if self.pos >= len(self.data): break
                    byte = self.data[self.pos]
                    mask = (1 << remaining) - 1
                    res |= ((byte >> self.bitpos) & mask) << (length - remaining)
                    consumed = min(8 - self.bitpos, remaining)
                    self.bitpos += consumed
                    remaining -= consumed
                    if self.bitpos >= 8:
                        self.pos += 1
                        self.bitpos -= 8
        else:
            dword1 = struct.unpack_from('<I', self.data, self.pos)[0]
            dword2 = struct.unpack_from('<I', self.data, self.pos + 4)[0] if self.pos + 4 < len(self.data) else 0
            res = dword1 >> self.bitpos
            done = 32 - self.bitpos
            remaining = length - done
            mask = (1 << remaining) - 1
            res |= (dword2 & mask) << done
            self.bitpos += length

        while self.bitpos >= 8:
            self.bitpos -= 8
            self.pos += 1
        return res

    def align(self, bytes_align):
        if self.bitpos != 0:
            self.pos += 1
            self.bitpos = 0
        while (self.pos % bytes_align) != 0:
            self.pos += 1

    def tell(self):
        return self.pos

    def seek(self, pos):
        self.bitpos = 0
        self.pos = pos

class WriteStream:
    def __init__(self):
        self.data = bytearray()
        self.pos = 0
        self.pending_bits = 0
        self.bitpos = 0

    def prep(self, length):
        if self.bitpos != 0:
            raise ValueError("Only supported when aligned")
        while len(self.data) < self.pos + length:
            self.data.append(0)

    def write_u8(self, v):
        self.prep(1)
        struct.pack_into('<B', self.data, self.pos, v)
        self.pos += 1

    def write_u16(self, v):
        self.prep(2)
        struct.pack_into('<H', self.data, self.pos, v)
        self.pos += 2

    def write_s32(self, v):
        self.prep(4)
        struct.pack_into('<i', self.data, self.pos, v)
        self.pos += 4

    def write_u32(self, v):
        self.prep(4)
        struct.pack_into('<I', self.data, self.pos, v)
        self.pos += 4

    def write_str(self, length, v):
        self.prep(length)
        b = str(v).encode('ascii', 'ignore')[:length]
        b = b.ljust(length, b'\x00')
        self.data[self.pos:self.pos+length] = b
        self.pos += length

    def flush_bits(self):
        if self.bitpos == 0: return
        size = (self.bitpos + 7) // 8
        self.bitpos = 0
        if size == 1:
            self.write_u8(self.pending_bits & 0xFF)
        elif size == 2:
            self.write_u16(self.pending_bits & 0xFFFF)
        elif size == 3:
            self.write_u16(self.pending_bits & 0xFFFF)
            self.write_u8((self.pending_bits >> 16) & 0xFF)
        elif size == 4:
            self.write_u32(self.pending_bits & 0xFFFFFFFF)
        self.pending_bits = 0

    def write_bits(self, length, v):
        if self.bitpos + length > 32:
            left = 32 - self.bitpos
            self.write_bits(left, v)
            self.write_bits(length - left, v >> left)
            return
        elif length == 32 and self.bitpos == 0:
            self.write_u32(v)
            return

        mask = (1 << length) - 1
        self.pending_bits |= (v & mask) << self.bitpos
        self.bitpos += length

        if self.bitpos == 32:
            self.flush_bits()

    def align(self, bytes_align):
        self.flush_bits()
        while (self.pos % bytes_align) != 0:
            self.write_u8(0)

    def get_data(self):
        self.flush_bits()
        return bytes(self.data[:self.pos])

class VChar:
    def __init__(self):
        self.idx = 0
        self.ch = 0
        self.bmp = None
        self.w = 0
        self.h = 0
        self.d = 0
        self.a = 0
        self.v = 0
        self.t = 0
        self.rle = None
        self.rlen = 0
        self.hdr = None
        self.hlen = 0
        self.sh = None

class ConverterCore:
    def __init__(self, magic_arr, fonthdr_arr):
        self.magic = magic_arr
        self.fonthdr = bytearray(fonthdr_arr)
        self.ascale = 1.0
        self.blur = 2.0
        self.intensity = 0.8
        self.font_size = 24

    def buildrle_add(self, x, v, i):
        if x is None:
            return i + 1
        if i & 1:
            x[i // 2] |= (v << 4) & 0xFF
        else:
            x[i // 2] |= v & 0x0F
        return i + 1

    def buildrle_int(self, x, p, l):
        i = 0
        j = 0
        while j < l:
            k = j
            while k < l and (k - j) < 8:
                if p[k] != p[j]:
                    break
                k += 1
            k -= j
            
            if k > 1:
                i = self.buildrle_add(x, k - 1, i)
                i = self.buildrle_add(x, p[j], i)
                j += k
            else:
                k = j
                while k < (l - 1) and (k - j) < 8:
                    if p[k] == p[k + 1]:
                        break
                    k += 1
                if k == l - 1 and (k - j) < 8:
                    k += 1
                if k == j:
                    raise ValueError("RLE encoding error")
                i = self.buildrle_add(x, 16 - (k - j), i)
                while j < k:
                    i = self.buildrle_add(x, p[j], i)
                    j += 1
        return (i + 1) // 2

    def buildrle(self, p, l):
        rlen = self.buildrle_int(None, p, l)
        x = bytearray(rlen)
        self.buildrle_int(x, p, l)
        return x, rlen

    def putv(self, n, p, b, v):
        for i in range(n):
            if v & 1:
                p[b // 8] |= 1 << (b % 8)
            else:
                p[b // 8] &= ~(1 << (b % 8))
            v >>= 1
            b += 1
        return b

    def packchar(self, v):
        tbmp = [0] * (v.w * v.h)
        for j in range(v.h):
            for i in range(v.w):
                tbmp[i * v.h + j] = v.bmp[j * v.w + i]
        
        v.rle, v.rlen = self.buildrle(v.bmp, v.w * v.h)
        trle, trlen = self.buildrle(tbmp, v.w * v.h)
        
        if v.rlen > trlen:
            v.rle = trle
            v.rlen = trlen
            v.t = 2
        else:
            v.t = 1
        
        i = 0
        v.hlen = 12 if v.idx >= 0 else 6
        v.hdr = bytearray(v.hlen)
        
        if v.v >= 35:
            v.v = 35
        
        i = self.putv(14, v.hdr, i, v.rlen + v.hlen)
        i = self.putv(7, v.hdr, i, v.w)
        i = self.putv(7, v.hdr, i, v.h)
        i = self.putv(7, v.hdr, i, v.d)
        i = self.putv(7, v.hdr, i, v.a)
        i = self.putv(2, v.hdr, i, v.t)
        
        if v.hlen == 12:
            i = self.putv(1, v.hdr, i, 1)
            i = self.putv(4, v.hdr, i, 7)
            i = self.putv(6, v.hdr, i, self.magic[v.idx])
            i = self.putv(9, v.hdr, i, v.idx)
            i = self.putv(8, v.hdr, i, 0x00)
            i = self.putv(8, v.hdr, i, 0x00)
            i = self.putv(8, v.hdr, i, 0x00)
            i = self.putv(2, v.hdr, i, 0x0)
            i = self.putv(6, v.hdr, i, v.v)
        else:
            i = self.putv(1, v.hdr, i, 0)
            i = self.putv(3, v.hdr, i, 0)
        
        if v.sh:
            self.packchar(v.sh)

    def sqrf(self, x):
        return x * x

    def blurpass(self, b, w, h, r, s):
        c = [0.0] * (w * h)
        d = [0.0] * (w * h)
        m = int(2.0 * r + 0.5)
        k = [0.0] * (2 * m + 1)
        rf = s / (r * 1.77245)
        
        for j in range(h):
            for i in range(w):
                c[j * w + i] = b[j * w + i]
        
        for t in range(-m, m + 1):
            k[t + m] = rf * math.exp(-self.sqrf(t / r))
        
        for j in range(h):
            for i in range(w):
                x = 0.0
                for t in range(-m, m + 1):
                    if 0 <= (t + i) < w:
                        x += c[j * w + (t + i)] * k[t + m]
                d[j * w + i] = x
        
        for j in range(h):
            for i in range(w):
                x = 0.0
                for t in range(-m, m + 1):
                    if 0 <= (t + j) < h:
                        x += d[(t + j) * w + i] * k[t + m]
                c[j * w + i] = x
        
        for j in range(h):
            for i in range(w):
                val = c[j * w + i] + 0.5
                val = max(0.0, min(15.0, val))
                b[j * w + i] = int(val)

    def createchars(self, face, sh_face):
        n = struct.unpack_from('<I', self.fonthdr, 0x14)[0]
        v = [VChar() for _ in range(n)]
        char_codes = struct.unpack_from(f'<{n}H', self.fonthdr, 0x1760)
        
        max_height = 0
        for i in range(n):
            face.set_char_size(0, self.font_size * 64, 0, 96)
            face.load_char(char_codes[i], freetype.FT_LOAD_DEFAULT)
            face.glyph.render(freetype.FT_RENDER_MODE_NORMAL)
            bitmap = face.glyph.bitmap
            if bitmap.rows > max_height:
                max_height = bitmap.rows
        
        for i in range(n):
            v[i].idx = i
            v[i].ch = char_codes[i]
            v[i].sh = VChar()
            v[i].sh.idx = -1
            v[i].sh.ch = 0
            self.loadchar(v[i], face, sh_face, max_height)
            self.packchar(v[i])
        return v, n

    def loadchar(self, v, face, sh_face, max_height):
        face.set_char_size(0, self.font_size * 64, 0, 96)
        face.load_char(v.ch, freetype.FT_LOAD_DEFAULT)
        face.glyph.render(freetype.FT_RENDER_MODE_NORMAL)
        
        bitmap = face.glyph.bitmap
        v.w = bitmap.width
        v.h = bitmap.rows
        v.a = face.glyph.bitmap_top
        v.d = face.glyph.bitmap_left
        
        advance = face.glyph.advance.x >> 6
        v.v = max(advance, v.w)
        v.v = int(v.v * self.ascale + 0.5)
        
        if not v.w or not v.h:
            v.bmp = [0]
        else:
            original_bmp = [0] * (v.w * v.h)
            buffer = bitmap.buffer
            for j in range(v.h):
                for i in range(v.w):
                    original_bmp[j * v.w + i] = buffer[j * bitmap.pitch + i] >> 4
            
            min_x, min_y = v.w, v.h
            max_x, max_y = 0, 0
            for y in range(v.h):
                for x in range(v.w):
                    if original_bmp[y * v.w + x] > 0:
                        if x < min_x: min_x = x
                        if x > max_x: max_x = x
                        if y < min_y: min_y = y
                        if y > max_y: max_y = y
            
            glyph_width = max_x - min_x + 1 if max_x >= min_x else 0
            glyph_height = max_y - min_y + 1 if max_y >= min_y else 0
            
            if glyph_width > 0 and glyph_height > 0:
                glyph_bmp = [0] * (glyph_width * glyph_height)
                for y in range(glyph_height):
                    for x in range(glyph_width):
                        glyph_bmp[y * glyph_width + x] = original_bmp[(min_y + y) * v.w + (min_x + x)]
                
                new_height = max_height
                new_width = glyph_width
                y_offset = (new_height - glyph_height) // 2
                
                v.bmp = [0] * (new_width * new_height)
                for y in range(glyph_height):
                    for x in range(glyph_width):
                        if 0 <= (y + y_offset) < new_height:
                            v.bmp[(y + y_offset) * new_width + x] = glyph_bmp[y * glyph_width + x]
                
                v.w = new_width
                v.h = new_height
                v.d += min_x
                v.a = v.a - min_y + y_offset
            else:
                v.bmp = [0] * (1 * max_height)
                v.w = 1
                v.h = max_height
        
        sh_face.set_char_size(0, (self.font_size // 2) * 64, 0, 96)
        sh_face.load_char(v.ch, freetype.FT_LOAD_DEFAULT)
        sh_face.glyph.render(freetype.FT_RENDER_MODE_NORMAL)
        
        sh_bitmap = sh_face.glyph.bitmap
        v.sh.w = sh_bitmap.width + 8
        v.sh.h = sh_bitmap.rows + 8
        v.sh.a = 4 + sh_face.glyph.bitmap_top
        v.sh.d = -4 + sh_face.glyph.bitmap_left
        
        v.sh.bmp = [0] * (v.sh.w * v.sh.h)
        sh_buffer = sh_bitmap.buffer
        
        for j in range(v.sh.h - 8):
            for i in range(v.sh.w - 8):
                if j < sh_bitmap.rows and i < sh_bitmap.width:
                    v.sh.bmp[(j + 4) * v.sh.w + (i + 4)] = sh_buffer[j * sh_bitmap.pitch + i] >> 4
        
        self.blurpass(v.sh.bmp, v.sh.w, v.sh.h, self.blur, self.intensity)

    def createptrs(self, v, n):
        ds = 0
        pl = 0
        for i in range(n):
            ds += v[i].rlen + v[i].hlen + v[i].sh.rlen + v[i].sh.hlen
            ds = (ds + 3) & ~3
        while (4 << pl) < ds:
            pl += 1
        
        s = ((pl * n + 31) // 32) * 4
        p = bytearray(s)
        
        ds = 0
        j = 0
        for i in range(n):
            val = ds // 4
            for bit in range(pl):
                if val & (1 << bit):
                    p[j // 8] |= 1 << (j % 8)
                j += 1
            ds += v[i].rlen + v[i].hlen + v[i].sh.rlen + v[i].sh.hlen
            ds = (ds + 3) & ~3
        
        return p, s, pl

    def fixupheader(self, name, style, l):
        name_bytes = name.encode('ascii') if isinstance(name, str) else name
        style_bytes = style.encode('ascii') if isinstance(style, str) else style
        
        if len(name_bytes) > 64:
            name_bytes = name_bytes[:64]
        if len(style_bytes) > 64:
            style_bytes = style_bytes[:64]
        
        self.fonthdr[0x35:0x35+len(name_bytes)] = name_bytes
        self.fonthdr[0x75:0x75+len(style_bytes)] = style_bytes
        struct.pack_into('<I', self.fonthdr, 0x1C, l)

    def process(self, input_path, output_path, f_size):
        self.font_size = f_size
        face = freetype.Face(input_path)
        sh_face = freetype.Face(input_path)
        v, n = self.createchars(face, sh_face)
        p, s, l = self.createptrs(v, n)
        
        ts = face.style_name if face.style_name else ""
        family_name = face.family_name if face.family_name else ""
        self.fixupheader(family_name, ts, l)
        
        with open(output_path, 'wb') as f:
            f.write(self.fonthdr[:16504])
            f.write(p)
            for i in range(n):
                f.write(v[i].hdr)
                f.write(v[i].rle)
                f.write(v[i].sh.hdr)
                f.write(v[i].sh.rle)
                pad_len = (4 - ((v[i].rlen + v[i].hlen + v[i].sh.rlen + v[i].sh.hlen) % 4)) % 4
                f.write(b'\x00' * pad_len)

