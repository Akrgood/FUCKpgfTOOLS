    def open_ttf_converter(self):
        conv_win = ctk.CTkToplevel(self)
        conv_win.title("TTF/OTF to PGF")
        conv_win.geometry("400x280")
        conv_win.transient(self)
        conv_win.grab_set()
        
        selected_font = tk.StringVar()
        
        def select_font():
            path = filedialog.askopenfilename(filetypes=[("Fonts", "*.ttf *.otf")])
            if path:
                selected_font.set(path)
                
        def start_convert():
            font_path = selected_font.get()
            if not font_path:
                return
            size_val = int(size_slider.get())
            self.show_save_options(conv_win, font_path, size_val)

        def slider_event(value):
            size_label_val.configure(text=f"{int(value)} px")

        ctk.CTkButton(conv_win, text="Select a font", command=select_font, fg_color="#8b0000", hover_color="#cc0000").pack(pady=20)
        ctk.CTkLabel(conv_win, textvariable=selected_font, text_color="#aaaaaa", wraplength=350).pack(pady=5)
        
        ctk.CTkLabel(conv_win, text="Font size:").pack()
        
        size_slider = ctk.CTkSlider(conv_win, from_=8, to=100, command=slider_event, fg_color="#333333", progress_color="#8b0000", button_color="#ff0000")
        size_slider.set(24)
        size_slider.pack(pady=(10, 5))
        
        size_label_val = ctk.CTkLabel(conv_win, text="24 px", text_color="#ffffff")
        size_label_val.pack(pady=(0, 10))
        
        ctk.CTkButton(conv_win, text="Convert", command=start_convert, fg_color="#8b0000", hover_color="#cc0000").pack(pady=10)

    def show_save_options(self, parent_win, font_path, size_val):
        opt_win = ctk.CTkToplevel(parent_win)
        opt_win.title("Saving")
        opt_win.geometry("300x150")
        opt_win.transient(parent_win)
        opt_win.grab_set()
        
        def save_and_close(open_after):
            save_path = filedialog.asksaveasfilename(defaultextension=".pgf", filetypes=[("PGF", "*.pgf")])
            if save_path:
                try:
                    core = ConverterCore(self.magic, self.fonthdr_template)
                    core.process(font_path, save_path, size_val)
                    opt_win.destroy()
                    parent_win.destroy()
                    if open_after:
                        with open(save_path, "rb") as f:
                            self.parse_pgf(f.read())
                except Exception as e:
                    messagebox.showerror("Error", str(e))

        ctk.CTkButton(opt_win, text="Save to ...", command=lambda: save_and_close(False), fg_color="#8b0000", hover_color="#cc0000").pack(pady=15, fill="x", padx=20)
        ctk.CTkButton(opt_win, text="Save to ... and open in the editor", command=lambda: save_and_close(True), fg_color="#8b0000", hover_color="#cc0000").pack(pady=10, fill="x", padx=20)

